{
  "name": "@mwa/monitoring-app",
  "version": "0.1.0",
  "private": true,
  "description": "Monitoring frontend SSR baseline workspace",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "tsx --test src/**/*.unit.test.ts",
    "test:integration": "tsx --test src/**/*.integration.test.ts",
    "test:e2e": "tsx --test src/**/*.e2e.test.ts",
    "coverage": "c8 --reporter=text --reporter=lcov npm run test"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "@types/supertest": "^6.0.3",
    "c8": "^10.1.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
