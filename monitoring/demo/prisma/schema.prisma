generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Attachment {
  id        String @id @default(uuid()) @db.Uuid
  name      String
  extension String
  url       String

  @@map("attachments")
}

model Article {
  id        String    @id @default(uuid()) @db.Uuid
  createdAt DateTime  @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  snapshots ArticleSnapshot[]
  comments  ArticleComment[]

  @@map("articles")
}

model ArticleSnapshot {
  id        String @id @default(uuid()) @db.Uuid
  articleId String @map("article_id") @db.Uuid
  format    String
  title     String
  body      String

  article                Article                        @relation(fields: [articleId], references: [id])
  saleSnapshotFavorites  SaleSnapshotInquiryFavorite[]

  @@index([articleId])
  @@map("article_snapshots")
}

model ArticleComment {
  id        String   @id @default(uuid()) @db.Uuid
  articleId String   @map("article_id") @db.Uuid
  parentId  String?  @map("parent_id") @db.Uuid
  createdAt DateTime @map("created_at")

  article  Article                 @relation(fields: [articleId], references: [id])
  parent   ArticleComment?         @relation("ArticleCommentTree", fields: [parentId], references: [id])
  children ArticleComment[]        @relation("ArticleCommentTree")
  snapshots ArticleCommentSnapshot[]

  @@index([articleId])
  @@index([parentId])
  @@map("article_comments")
}

model ArticleCommentSnapshot {
  id               String @id @default(uuid()) @db.Uuid
  articleCommentId String @map("article_comment_id") @db.Uuid
  format           String
  body             String

  articleComment ArticleComment @relation(fields: [articleCommentId], references: [id])

  @@index([articleCommentId])
  @@map("article_comment_snapshots")
}

model Channel {
  id   String @id @default(uuid()) @db.Uuid
  code String @unique
  name String

  categories    ChannelCategory[]
  citizens      Citizen[]
  members       Member[]
  externalUsers ExternalUser[]
  customers     Customer[]

  @@map("channels")
}

model ChannelCategory {
  id        String  @id @default(uuid()) @db.Uuid
  channelId String  @map("channel_id") @db.Uuid
  parentId  String? @map("parent_id") @db.Uuid
  code      String
  name      String

  channel                Channel                @relation(fields: [channelId], references: [id])
  parent                 ChannelCategory?       @relation("ChannelCategoryTree", fields: [parentId], references: [id])
  children               ChannelCategory[]      @relation("ChannelCategoryTree")
  saleSnapshotCategories SaleSnapshotCategory[]

  @@index([channelId])
  @@index([parentId])
  @@map("channel_categories")
}

model Section {
  id   String @id @default(uuid()) @db.Uuid
  code String @unique
  name String

  sales Sale[]

  @@map("sections")
}

model Citizen {
  id        String @id @default(uuid()) @db.Uuid
  channelId String @map("channel_id") @db.Uuid
  mobile    String
  name      String

  channel          Channel          @relation(fields: [channelId], references: [id])
  members          Member[]
  externalUsers    ExternalUser[]
  customers        Customer[]
  depositHistories DepositHistory[]
  mileageHistories MileageHistory[]

  @@index([channelId])
  @@map("citizens")
}

model Member {
  id        String @id @default(uuid()) @db.Uuid
  channelId String @map("channel_id") @db.Uuid
  citizenId String @map("citizen_id") @db.Uuid
  nickname  String

  channel       Channel       @relation(fields: [channelId], references: [id])
  citizen       Citizen       @relation(fields: [citizenId], references: [id])
  seller        Seller?
  administrator Administrator?
  customers     Customer[]

  @@index([channelId])
  @@index([citizenId])
  @@map("members")
}

model ExternalUser {
  id          String @id @default(uuid()) @db.Uuid
  channelId   String @map("channel_id") @db.Uuid
  citizenId   String @map("citizen_id") @db.Uuid
  application String
  uid         String

  channel   Channel    @relation(fields: [channelId], references: [id])
  citizen   Citizen    @relation(fields: [citizenId], references: [id])
  customers Customer[]

  @@index([channelId])
  @@index([citizenId])
  @@unique([channelId, uid])
  @@map("external_users")
}

model Customer {
  id             String @id @default(uuid()) @db.Uuid
  channelId      String @map("channel_id") @db.Uuid
  memberId       String? @map("member_id") @db.Uuid
  externalUserId String? @map("external_user_id") @db.Uuid
  citizenId      String? @map("citizen_id") @db.Uuid

  channel        Channel                        @relation(fields: [channelId], references: [id])
  member         Member?                        @relation(fields: [memberId], references: [id])
  externalUser   ExternalUser?                  @relation(fields: [externalUserId], references: [id])
  citizen        Citizen?                       @relation(fields: [citizenId], references: [id])
  sellerSales    Sale[]                         @relation("SaleSellerCustomer")
  carts          Cart[]
  orders         OrderEntity[]
  coupons        Coupon[]
  couponTickets  CouponTicket[]
  inquiries      SaleSnapshotInquiry[]
  inquiryAnswers SaleSnapshotInquiryAnswer[]
  saleFavorites  SaleFavorite[]
  inquiryFavorites SaleSnapshotInquiryFavorite[]
  addressFavorites AddressFavorite[]
  apiRequestLogs ApiRequestLog[]

  @@index([channelId])
  @@index([memberId])
  @@index([externalUserId])
  @@index([citizenId])
  @@map("customers")
}

model Seller {
  id       String @id @default(uuid()) @db.Uuid
  memberId String @unique @map("member_id") @db.Uuid

  member     Member      @relation(fields: [memberId], references: [id])
  orderItems OrderItem[]

  @@map("sellers")
}

model Administrator {
  id       String @id @default(uuid()) @db.Uuid
  memberId String @unique @map("member_id") @db.Uuid

  member Member @relation(fields: [memberId], references: [id])

  @@map("administrators")
}

model Address {
  id   String @id @default(uuid()) @db.Uuid
  name String
  city String

  orders          OrderEntity[]
  orderPayments   OrderPayment[]
  addressFavorites AddressFavorite[]

  @@map("addresses")
}

model Sale {
  id               String @id @default(uuid()) @db.Uuid
  sectionId        String @map("section_id") @db.Uuid
  sellerCustomerId String @map("seller_customer_id") @db.Uuid

  section        Section       @relation(fields: [sectionId], references: [id])
  sellerCustomer Customer      @relation("SaleSellerCustomer", fields: [sellerCustomerId], references: [id])
  snapshots      SaleSnapshot[]
  saleFavorites  SaleFavorite[]

  @@index([sectionId])
  @@index([sellerCustomerId])
  @@map("sales")
}

model SaleSnapshot {
  id         String @id @default(uuid()) @db.Uuid
  saleId     String @map("sale_id") @db.Uuid

  sale              Sale                     @relation(fields: [saleId], references: [id])
  categories        SaleSnapshotCategory[]
  contents          SaleSnapshotContent[]
  tags              SaleSnapshotTag[]
  units             SaleSnapshotUnit[]
  cartItems         CartItem[]
  inquiries         SaleSnapshotInquiry[]
  saleFavorites     SaleFavorite[]

  @@index([saleId])
  @@map("sale_snapshots")
}

model SaleSnapshotCategory {
  id                String @id @default(uuid()) @db.Uuid
  saleSnapshotId    String @map("sale_snapshot_id") @db.Uuid
  channelCategoryId String @map("channel_category_id") @db.Uuid

  saleSnapshot    SaleSnapshot    @relation(fields: [saleSnapshotId], references: [id])
  channelCategory ChannelCategory @relation(fields: [channelCategoryId], references: [id])

  @@index([saleSnapshotId])
  @@index([channelCategoryId])
  @@map("sale_snapshot_categories")
}

model SaleSnapshotContent {
  id             String @id @default(uuid()) @db.Uuid
  saleSnapshotId String @map("sale_snapshot_id") @db.Uuid
  title          String

  saleSnapshot SaleSnapshot @relation(fields: [saleSnapshotId], references: [id])

  @@index([saleSnapshotId])
  @@map("sale_snapshot_contents")
}

model SaleSnapshotTag {
  id             String @id @default(uuid()) @db.Uuid
  saleSnapshotId String @map("sale_snapshot_id") @db.Uuid
  value          String

  saleSnapshot SaleSnapshot @relation(fields: [saleSnapshotId], references: [id])

  @@index([saleSnapshotId])
  @@map("sale_snapshot_tags")
}

model SaleSnapshotUnit {
  id             String @id @default(uuid()) @db.Uuid
  saleSnapshotId String @map("sale_snapshot_id") @db.Uuid
  name           String

  saleSnapshot SaleSnapshot            @relation(fields: [saleSnapshotId], references: [id])
  options      SaleSnapshotUnitOption[]
  stocks       SaleSnapshotUnitStock[]
  cartItemStocks CartItemStock[]

  @@index([saleSnapshotId])
  @@map("sale_snapshot_units")
}

model SaleSnapshotUnitOption {
  id                 String @id @default(uuid()) @db.Uuid
  saleSnapshotUnitId String @map("sale_snapshot_unit_id") @db.Uuid
  name               String

  saleSnapshotUnit SaleSnapshotUnit                @relation(fields: [saleSnapshotUnitId], references: [id])
  candidates       SaleSnapshotUnitOptionCandidate[]
  cartItemStockChoices CartItemStockChoice[]

  @@index([saleSnapshotUnitId])
  @@map("sale_snapshot_unit_options")
}

model SaleSnapshotUnitOptionCandidate {
  id                       String @id @default(uuid()) @db.Uuid
  saleSnapshotUnitOptionId String @map("sale_snapshot_unit_option_id") @db.Uuid
  name                     String

  saleSnapshotUnitOption SaleSnapshotUnitOption @relation(fields: [saleSnapshotUnitOptionId], references: [id])
  cartItemStockChoices  CartItemStockChoice[]

  @@index([saleSnapshotUnitOptionId])
  @@map("sale_snapshot_unit_option_candidates")
}

model SaleSnapshotUnitStock {
  id                 String  @id @default(uuid()) @db.Uuid
  saleSnapshotUnitId String  @map("sale_snapshot_unit_id") @db.Uuid
  name               String
  realPrice          Decimal @map("real_price") @db.Decimal(12, 2)
  quantity           Int

  saleSnapshotUnit SaleSnapshotUnit @relation(fields: [saleSnapshotUnitId], references: [id])
  cartItemStocks   CartItemStock[]

  @@index([saleSnapshotUnitId])
  @@map("sale_snapshot_unit_stocks")
}

model Cart {
  id         String @id @default(uuid()) @db.Uuid
  customerId String @map("customer_id") @db.Uuid
  actorType  String @map("actor_type")

  customer Customer   @relation(fields: [customerId], references: [id])
  items    CartItem[]

  @@index([customerId])
  @@map("carts")
}

model CartItem {
  id             String @id @default(uuid()) @db.Uuid
  cartId         String @map("cart_id") @db.Uuid
  saleSnapshotId String @map("sale_snapshot_id") @db.Uuid
  volume         Int

  cart         Cart            @relation(fields: [cartId], references: [id])
  saleSnapshot SaleSnapshot    @relation(fields: [saleSnapshotId], references: [id])
  stocks       CartItemStock[]
  orderItem    OrderItem?

  @@index([cartId])
  @@index([saleSnapshotId])
  @@map("cart_items")
}

model CartItemStock {
  id                    String @id @default(uuid()) @db.Uuid
  cartItemId            String @map("cart_item_id") @db.Uuid
  saleSnapshotUnitId    String @map("sale_snapshot_unit_id") @db.Uuid
  saleSnapshotUnitStockId String @map("sale_snapshot_unit_stock_id") @db.Uuid
  quantity              Int

  cartItem             CartItem              @relation(fields: [cartItemId], references: [id])
  saleSnapshotUnit     SaleSnapshotUnit      @relation(fields: [saleSnapshotUnitId], references: [id])
  saleSnapshotUnitStock SaleSnapshotUnitStock @relation(fields: [saleSnapshotUnitStockId], references: [id])
  choices              CartItemStockChoice[]

  @@index([cartItemId])
  @@index([saleSnapshotUnitId])
  @@index([saleSnapshotUnitStockId])
  @@map("cart_item_stocks")
}

model CartItemStockChoice {
  id                                String @id @default(uuid()) @db.Uuid
  cartItemStockId                   String @map("cart_item_stock_id") @db.Uuid
  saleSnapshotUnitOptionId          String @map("sale_snapshot_unit_option_id") @db.Uuid
  saleSnapshotUnitOptionCandidateId String @map("sale_snapshot_unit_option_candidate_id") @db.Uuid
  value                             String

  cartItemStock                   CartItemStock                  @relation(fields: [cartItemStockId], references: [id])
  saleSnapshotUnitOption          SaleSnapshotUnitOption         @relation(fields: [saleSnapshotUnitOptionId], references: [id])
  saleSnapshotUnitOptionCandidate SaleSnapshotUnitOptionCandidate @relation(fields: [saleSnapshotUnitOptionCandidateId], references: [id])

  @@index([cartItemStockId])
  @@index([saleSnapshotUnitOptionId])
  @@index([saleSnapshotUnitOptionCandidateId])
  @@map("cart_item_stock_choices")
}

model OrderEntity {
  id         String  @id @default(uuid()) @db.Uuid
  customerId String  @map("customer_id") @db.Uuid
  addressId  String  @map("address_id") @db.Uuid
  cash       Decimal @db.Decimal(12, 2)
  deposit    Decimal @db.Decimal(12, 2)
  mileage    Decimal @db.Decimal(12, 2)

  customer             Customer             @relation(fields: [customerId], references: [id])
  address              Address              @relation(fields: [addressId], references: [id])
  items                OrderItem[]
  payment              OrderPayment?
  paymentAttempts      PaymentAttempt[]
  couponTicketPayments CouponTicketPayment[]

  @@index([customerId])
  @@index([addressId])
  @@map("orders")
}

model OrderItem {
  id         String @id @default(uuid()) @db.Uuid
  orderId    String @map("order_id") @db.Uuid
  cartItemId String @unique @map("cart_item_id") @db.Uuid
  sellerId   String @map("seller_id") @db.Uuid
  volume     Int

  order  OrderEntity         @relation(fields: [orderId], references: [id])
  cartItem CartItem          @relation(fields: [cartItemId], references: [id])
  seller Seller              @relation(fields: [sellerId], references: [id])
  review SaleSnapshotReview?

  @@index([orderId])
  @@index([sellerId])
  @@map("order_items")
}

model OrderPayment {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @unique @map("order_id") @db.Uuid
  addressId String   @map("address_id") @db.Uuid
  paidAt    DateTime @map("paid_at")

  order   OrderEntity @relation(fields: [orderId], references: [id])
  address Address     @relation(fields: [addressId], references: [id])

  @@index([addressId])
  @@map("order_payments")
}

model PaymentAttempt {
  id          String  @id @default(uuid()) @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  status      String
  amount      Decimal @db.Decimal(12, 2)
  failureCode String? @map("failure_code")

  order OrderEntity @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
  @@map("payment_attempts")
}

model Coupon {
  id         String  @id @default(uuid()) @db.Uuid
  customerId String  @map("customer_id") @db.Uuid
  name       String
  unit       String
  value      Decimal @db.Decimal(12, 2)

  customer Customer      @relation(fields: [customerId], references: [id])
  tickets  CouponTicket[]

  @@index([customerId])
  @@map("coupons")
}

model CouponTicket {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  couponId   String   @map("coupon_id") @db.Uuid
  expiredAt  DateTime @map("expired_at")

  customer Customer              @relation(fields: [customerId], references: [id])
  coupon   Coupon                @relation(fields: [couponId], references: [id])
  payments CouponTicketPayment[]

  @@index([customerId])
  @@index([couponId])
  @@map("coupon_tickets")
}

model CouponTicketPayment {
  id             String @id @default(uuid()) @db.Uuid
  couponTicketId String @map("coupon_ticket_id") @db.Uuid
  orderId        String @map("order_id") @db.Uuid

  couponTicket CouponTicket @relation(fields: [couponTicketId], references: [id])
  order       OrderEntity  @relation(fields: [orderId], references: [id])

  @@index([couponTicketId])
  @@index([orderId])
  @@map("coupon_ticket_payments")
}

model Deposit {
  id        String @id @default(uuid()) @db.Uuid
  code      String @unique
  source    String
  direction Int

  histories DepositHistory[]

  @@map("deposits")
}

model DepositHistory {
  id        String  @id @default(uuid()) @db.Uuid
  depositId String  @map("deposit_id") @db.Uuid
  citizenId String  @map("citizen_id") @db.Uuid
  value     Decimal @db.Decimal(12, 2)
  balance   Decimal @db.Decimal(12, 2)

  deposit Deposit @relation(fields: [depositId], references: [id])
  citizen Citizen @relation(fields: [citizenId], references: [id])

  @@index([depositId])
  @@index([citizenId])
  @@map("deposit_histories")
}

model Mileage {
  id        String @id @default(uuid()) @db.Uuid
  code      String @unique
  source    String
  direction Int

  histories MileageHistory[]

  @@map("mileages")
}

model MileageHistory {
  id        String  @id @default(uuid()) @db.Uuid
  mileageId String  @map("mileage_id") @db.Uuid
  citizenId String  @map("citizen_id") @db.Uuid
  value     Decimal @db.Decimal(12, 2)
  balance   Decimal @db.Decimal(12, 2)

  mileage Mileage @relation(fields: [mileageId], references: [id])
  citizen Citizen @relation(fields: [citizenId], references: [id])

  @@index([mileageId])
  @@index([citizenId])
  @@map("mileage_histories")
}

model SaleSnapshotInquiry {
  id             String @id @default(uuid()) @db.Uuid
  saleSnapshotId String @map("sale_snapshot_id") @db.Uuid
  customerId     String @map("customer_id") @db.Uuid
  type           String

  saleSnapshot SaleSnapshot                @relation(fields: [saleSnapshotId], references: [id])
  customer     Customer                    @relation(fields: [customerId], references: [id])
  question     SaleSnapshotQuestion?
  review       SaleSnapshotReview?
  answers      SaleSnapshotInquiryAnswer[]
  favorites    SaleSnapshotInquiryFavorite[]

  @@index([saleSnapshotId])
  @@index([customerId])
  @@map("sale_snapshot_inquiries")
}

model SaleSnapshotQuestion {
  id                    String  @id @default(uuid()) @db.Uuid
  saleSnapshotInquiryId String  @unique @map("sale_snapshot_inquiry_id") @db.Uuid
  secret                Boolean

  saleSnapshotInquiry SaleSnapshotInquiry @relation(fields: [saleSnapshotInquiryId], references: [id])

  @@map("sale_snapshot_questions")
}

model SaleSnapshotReview {
  id                    String @id @default(uuid()) @db.Uuid
  saleSnapshotInquiryId String @unique @map("sale_snapshot_inquiry_id") @db.Uuid
  orderItemId           String @unique @map("order_item_id") @db.Uuid

  saleSnapshotInquiry SaleSnapshotInquiry @relation(fields: [saleSnapshotInquiryId], references: [id])
  orderItem          OrderItem            @relation(fields: [orderItemId], references: [id])

  @@map("sale_snapshot_reviews")
}

model SaleSnapshotInquiryAnswer {
  id                    String @id @default(uuid()) @db.Uuid
  saleSnapshotInquiryId String @map("sale_snapshot_inquiry_id") @db.Uuid
  sellerCustomerId      String @map("seller_customer_id") @db.Uuid

  saleSnapshotInquiry SaleSnapshotInquiry @relation(fields: [saleSnapshotInquiryId], references: [id])
  sellerCustomer     Customer             @relation(fields: [sellerCustomerId], references: [id])

  @@index([saleSnapshotInquiryId])
  @@index([sellerCustomerId])
  @@map("sale_snapshot_inquiry_answers")
}

model SaleFavorite {
  id             String @id @default(uuid()) @db.Uuid
  customerId     String @map("customer_id") @db.Uuid
  saleId         String @map("sale_id") @db.Uuid
  saleSnapshotId String @map("sale_snapshot_id") @db.Uuid

  customer     Customer     @relation(fields: [customerId], references: [id])
  sale         Sale         @relation(fields: [saleId], references: [id])
  saleSnapshot SaleSnapshot @relation(fields: [saleSnapshotId], references: [id])

  @@index([customerId])
  @@index([saleId])
  @@index([saleSnapshotId])
  @@unique([customerId, saleId, saleSnapshotId])
  @@map("sale_favorites")
}

model SaleSnapshotInquiryFavorite {
  id                    String @id @default(uuid()) @db.Uuid
  customerId            String @map("customer_id") @db.Uuid
  saleSnapshotInquiryId String @map("sale_snapshot_inquiry_id") @db.Uuid
  articleSnapshotId     String @map("article_snapshot_id") @db.Uuid

  customer            Customer            @relation(fields: [customerId], references: [id])
  saleSnapshotInquiry SaleSnapshotInquiry @relation(fields: [saleSnapshotInquiryId], references: [id])
  articleSnapshot     ArticleSnapshot     @relation(fields: [articleSnapshotId], references: [id])

  @@index([customerId])
  @@index([saleSnapshotInquiryId])
  @@index([articleSnapshotId])
  @@unique([customerId, saleSnapshotInquiryId, articleSnapshotId])
  @@map("sale_snapshot_inquiry_favorites")
}

model AddressFavorite {
  id         String @id @default(uuid()) @db.Uuid
  customerId String @map("customer_id") @db.Uuid
  addressId  String @map("address_id") @db.Uuid
  title      String

  customer Customer @relation(fields: [customerId], references: [id])
  address  Address  @relation(fields: [addressId], references: [id])

  @@index([customerId])
  @@index([addressId])
  @@unique([customerId, addressId])
  @@map("address_favorites")
}

model MonitoringEvent {
  id         String  @id @default(uuid()) @db.Uuid
  eventName  String  @map("event_name")
  entityType String  @map("entity_type")
  entityId   String  @map("entity_id")
  requestId  String? @map("request_id")
  userId     String  @map("user_id")

  apiRequestLog ApiRequestLog? @relation(fields: [requestId], references: [requestId])

  @@index([requestId])
  @@index([entityType, entityId])
  @@map("monitoring_events")
}

model ApiRequestLog {
  id         String  @id @default(uuid()) @db.Uuid
  requestId  String  @unique @map("request_id")
  customerId String? @map("customer_id") @db.Uuid
  method     String
  endpoint   String
  statusCode Int     @map("status_code")
  latencyMs  Int     @map("latency_ms")
  errorCode  String? @map("error_code")

  customer         Customer?         @relation(fields: [customerId], references: [id])
  monitoringEvents MonitoringEvent[]

  @@index([customerId])
  @@index([method, endpoint])
  @@index([statusCode])
  @@map("api_request_logs")
}

model AlertRecord {
  id         String @id @default(uuid()) @db.Uuid
  alertName  String @map("alert_name")
  severity   String
  status     String
  sourceType String @map("source_type")
  sourceRef  String @map("source_ref")

  @@index([severity, status])
  @@map("alert_records")
}
