        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 34 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (action) (rate(mwa_button_clicks_total[5m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
