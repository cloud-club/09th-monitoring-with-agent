    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 4,
      "title": "2) MWA 백엔드 HTTP — 실제 서버 핸들러 기준 (mwa_http_requests_total / mwa_http_request_duration_seconds)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "백엔드 메트릭 mwa_http_requests_total 은 service·handler·method·status_code 라벨을 가집니다. 이 패널은 backend 서비스 전체 요청 처리량을 최근 5분 평균 req/s로 표시합니다.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(mwa_http_requests_total{service=\"backend\"}[5m]))",
          "legendFormat": "backend total rps",
          "refId": "A"
        }
      ],
      "title": "HTTP 처리량 — backend 전체 합산 (초당, 최근 5분 평균)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "백엔드 HTTP 메트릭을 handler + method 기준으로 묶습니다. UUID 경로는 서버에서 :id 로 정규화되어 시계열이 폭증하지 않습니다.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (handler, method) (rate(mwa_http_requests_total{service=\"backend\"}[5m]))",
          "legendFormat": "{{method}} {{handler}}",
          "refId": "A"
        }
      ],
      "title": "HTTP 처리량 — 핸들러(handler)별 (초당, 최근 5분 평균)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
