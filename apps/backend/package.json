{
  "name": "@mwa/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 1 backend baseline (NestJS + MikroORM + Vitest + Playwright + Typia)",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/src/main.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test:policy": "node scripts/validate-test-policy.mjs",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config test/vitest.unit.config.ts",
    "test:integration": "vitest run --config test/vitest.integration.config.ts",
    "test:e2e": "playwright test -c test/playwright.config.ts",
    "test:integration:live": "vitest run --config test/vitest.live.config.ts",
    "test:live": "npm run test:integration:live",
    "test:ci": "npm run test:policy && npm run typecheck && npm run test:unit && npm run test:integration && npm run test:e2e",
    "coverage": "vitest run --config test/vitest.unit.config.ts --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.6.10",
    "@mikro-orm/nestjs": "^6.1.2",
    "@mikro-orm/sqlite": "^6.6.10",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typia": "^12.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.17",
    "@types/node": "^24.6.0",
    "@types/supertest": "^6.0.3",
    "@playwright/test": "^1.53.2",
    "supertest": "^7.1.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
