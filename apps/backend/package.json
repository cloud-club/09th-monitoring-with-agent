{
	"name": "@mwa/backend",
	"version": "0.1.0",
	"private": true,
	"description": "Phase 1 backend baseline (NestJS + TypeScript)",
	"scripts": {
		"dev": "tsx watch src/main.ts",
		"postinstall": "npm run db:generate",
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"lint": "eslint \"src/**/*.ts\"",
		"lint:fix": "npm run lint -- --fix",
		"format": "npm run lint:fix && prettier --write \"*.{json,mjs}\"",
		"format:check": "npm run lint && prettier --check \"*.{json,mjs}\"",
		"start": "node dist/main.js",
		"test:policy": "node scripts/validate-test-policy.mjs",
		"test": "npm run test:unit && npm run test:integration",
		"test:unit": "vitest run --config test/vitest.unit.config.ts",
		"test:integration": "vitest run --config test/vitest.integration.config.ts",
		"test:e2e": "playwright test -c test/playwright.config.ts",
		"test:e2e:smoke": "node scripts/run-seeded-smoke.mjs",
		"test:integration:live": "vitest run --config test/vitest.live.config.ts",
		"test:ci": "npm run test:policy && npm run typecheck && npm run test:unit && npm run test:integration && npm run test:e2e",
		"benchmark:api": "node scripts/run-k6-benchmark.mjs benchmarks/api-benchmark.k6.js",
		"benchmark:api:smoke": "node scripts/run-k6-benchmark.mjs benchmarks/api-benchmark.k6.js --vus 5 --duration 15s",
		"benchmark:format": "node scripts/format-k6-summary.mjs benchmarks/results/summary.json benchmarks/results/comment.md",
		"coverage": "vitest run --config test/vitest.unit.config.ts --coverage",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"db:generate": "prisma generate --schema prisma",
		"db:migrate": "mikro-orm migration:up",
		"db:migrate:dev": "mikro-orm migration:create",
		"db:seed": "prisma db seed --schema prisma",
		"db:reset:test": "prisma db push --force-reset --schema prisma && npm run db:seed",
		"db:assert:fixtures": "node test/fixtures/assert-deterministic-seed.js"
	},
	"prisma": {
		"seed": "node prisma/seed.js"
	},
	"overrides": {
		"@nestjs/core": {
			"path-to-regexp": "8.4.1"
		},
		"@nestjs/platform-express": {
			"path-to-regexp": "8.4.1"
		},
		"@prisma/config": {
			"effect": "3.21.0"
		},
		"@rushstack/node-core-library": {
			"ajv": "8.18.0"
		}
	},
	"dependencies": {
		"@mikro-orm/core": "^6.5.9",
		"@mikro-orm/migrations": "^6.5.9",
		"@mikro-orm/nestjs": "^6.1.1",
		"@mikro-orm/postgresql": "^6.5.9",
		"@nestjs/common": "^11.1.6",
		"@nestjs/core": "^11.1.6",
		"@nestjs/platform-express": "^11.1.6",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
		"@opentelemetry/resources": "^1.30.1",
		"@opentelemetry/sdk-trace-base": "^1.30.1",
		"@opentelemetry/sdk-trace-node": "^1.30.1",
		"@opentelemetry/semantic-conventions": "^1.30.1",
		"@prisma/client": "^6.5.0",
		"dotenv": "^17.2.3",
		"prom-client": "^15.1.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"typia": "^9.7.2"
	},
	"devDependencies": {
		"@mikro-orm/cli": "^6.5.9",
		"@nestjs/testing": "^11.1.6",
		"@playwright/test": "^1.53.2",
		"@ryoppippi/eslint-config": "^0.4.0",
		"@types/express": "^5.0.3",
		"@types/node": "^24.6.0",
		"@types/supertest": "^6.0.3",
		"eslint": "^9.38.0",
		"eslint-plugin-format": "^2.0.1",
		"prettier": "^3.6.2",
		"prisma": "^6.5.0",
		"supertest": "^7.1.4",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}
