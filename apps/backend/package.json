{
  "name": "@mwa/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 1 backend baseline (Express + TypeScript)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test:policy": "node scripts/validate-test-policy.mjs",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config test/vitest.unit.config.ts",
    "test:integration": "vitest run --config test/vitest.integration.config.ts",
    "test:e2e": "playwright test -c test/playwright.config.ts",
    "test:integration:live": "vitest run --config test/vitest.live.config.ts",
    "test:ci": "npm run test:policy && npm run typecheck && npm run test:unit && npm run test:integration && npm run test:e2e",
    "coverage": "vitest run --config test/vitest.unit.config.ts --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "prisma generate --schema prisma",
    "db:migrate": "prisma migrate deploy --schema prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma",
    "db:seed": "prisma db seed --schema prisma",
    "db:reset:test": "prisma migrate reset --force --skip-generate --schema prisma",
    "db:assert:fixtures": "node test/fixtures/assert-deterministic-seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "@types/supertest": "^6.0.3",
    "@playwright/test": "^1.53.2",
    "prisma": "^6.5.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
