{
	"name": "@mwa/backend",
	"version": "0.1.0",
	"private": true,
	"description": "Phase 1 backend baseline (NestJS + TypeScript)",
	"scripts": {
		"dev": "tsx watch src/main.ts",
		"build": "rm -rf dist && tsc -p tsconfig.json",
		"lint": "eslint \"src/**/*.ts\"",
		"lint:fix": "npm run lint -- --fix",
		"format": "npm run lint:fix && prettier --write \"*.{json,mjs}\"",
		"format:check": "npm run lint && prettier --check \"*.{json,mjs}\"",
		"start": "node dist/main.js",
		"test": "vitest run",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"db:migrate": "mikro-orm migration:up",
		"db:migrate:dev": "mikro-orm migration:create",
		"db:seed": "prisma db seed --schema prisma",
		"db:reset:test": "prisma migrate reset --force --skip-generate --schema prisma",
		"db:assert:fixtures": "node test/fixtures/assert-deterministic-seed.js"
	},
	"prisma": {
		"seed": "node prisma/seed.js"
	},
	"dependencies": {
		"@mikro-orm/core": "^6.5.9",
		"@mikro-orm/migrations": "^6.5.9",
		"@mikro-orm/nestjs": "^6.1.1",
		"@mikro-orm/postgresql": "^6.5.9",
		"@nestjs/common": "^11.1.6",
		"@nestjs/core": "^11.1.6",
		"@nestjs/platform-express": "^11.1.6",
		"@prisma/client": "^6.5.0",
		"dotenv": "^17.2.3",
		"prom-client": "^15.1.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"typia": "^9.7.2"
	},
	"devDependencies": {
		"@mikro-orm/cli": "^6.5.9",
		"@nestjs/testing": "^11.1.6",
		"@ryoppippi/eslint-config": "^0.4.0",
		"@types/express": "^5.0.3",
		"@types/node": "^24.6.0",
		"@types/supertest": "^6.0.3",
		"eslint": "^9.38.0",
		"eslint-plugin-format": "^2.0.1",
		"prettier": "^3.6.2",
		"prisma": "^6.5.0",
		"supertest": "^7.1.4",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}
